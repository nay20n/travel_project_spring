<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="placeMapper">
	<select id="selectPlaceImages" resultType="java.lang.String">
		<![CDATA[
			SELECT image "image" FROM places_images WHERE place_id=#{placeId}
		]]>
	</select>
	<select id="selectArrPlaceId" resultType="java.lang.String">
		<![CDATA[
			SELECT arr_place_id FROM boards WHERE bno=#{bno}
		]]>
	</select>
</mapper>